{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd harvest-connect-mobile-main && npm install && npm run build",
  "outputDirectory": "harvest-connect-mobile-main/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
